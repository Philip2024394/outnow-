{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/vendor", "destination": "/vendor.html" },
    { "source": "/vendor/(.*)", "destination": "/vendor.html" },
    { "source": "/driver", "destination": "/driver.html" },
    { "source": "/driver/(.*)", "destination": "/driver.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
